# Copia este archivo a .env y rellena los valores reales:
#   cp .env.example .env
#
# Obligatorios para arrancar el bot:
#   BOT_TOKEN + (DEEPSEEK_KEY o ANTHROPIC_KEY según LLM_PROVIDER)

# Token del bot de @BotFather
BOT_TOKEN=your_telegram_bot_token

# Proveedor LLM: deepseek (default) o anthropic
LLM_PROVIDER=deepseek
DEEPSEEK_KEY=your_deepseek_api_key
# DEEPSEEK_MODEL=deepseek-v4-pro

# Solo si LLM_PROVIDER=anthropic
ANTHROPIC_KEY=your_anthropic_api_key
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Opcional: extractor.py y backfill de historial VIP (Telethon user API)
# Obtené API_ID y API_HASH gratis en https://my.telegram.org
API_ID=your_api_id
API_HASH=your_api_hash

# Opcional: ruta del system prompt (default: diana_system_prompt.md)
# DIANA_SYSTEM_PROMPT_FILE=diana_system_prompt.md